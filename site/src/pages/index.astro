            </a>
            <a class="footer-rich__social-link" href="https://github.com/prb/ferric-rules/discussions" aria-label="Discussions">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4Z"/></svg>
            </a>
            <a class="footer-rich__social-link" href="https://github.com/prb/ferric-rules/issues" aria-label="Issues">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="M12 7v6"/><path d="M12 17h.01"/></svg>
            </a>
          </div>
        </div>

        <nav class="footer-rich__columns" aria-label="Footer navigation">
          <div class="footer-rich__column">
            <h2 class="footer-rich__heading">Docs</h2>
            <a class="footer-rich__link" href={sitePath('docs/getting-started/')}>Getting started</a>
            <a class="footer-rich__link" href={sitePath('docs/compatibility/')}>CLIPS compatibility</a>
