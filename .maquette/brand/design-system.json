      "usage": {
        "body": "Use Inter or a system UI fallback for page copy, guides, labels, navigation, and short-form documentation.",
        "label": "Use semibold Inter with exact casing for labels, tabs, badges, and compact state indicators.",
        "code": "Use IBM Plex Mono or a standard monospace fallback for CLIPS snippets, Rust snippets, tokens, tables, and technical data.",
        "h1": "Use measured, technical display headings with weight 700 and no negative tracking.",
        "h2": "Use section headings that feel architectural and calm, not oversized marketing display.",
        "h3": "Use for card groups, documentation sections, and feature summaries.",
        "h4": "Use for compact panels and component headings."
      },
      "font_strategy": {
        "heading_personality": "Precise, utilitarian, engineered, with enough weight for industrial authority but no condensed novelty treatment.",
        "body_personality": "Quiet documentation UI text optimized for long reading sessions.",
        "preferred_heading_fonts": "Inter, IBM Plex Sans, Source Sans 3, or equivalent modern grotesk.",
        "preferred_body_fonts": "Inter, system UI, Source Sans 3, or equivalent documentation-friendly sans.",
        "css_fallback_stacks": "Sans: \"Inter\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif. Mono: \"IBM Plex Mono\", \"SFMono-Regular\", Menlo, Monaco, Consolas, monospace. Optional long-form serif: \"Source Serif 4\", Georgia, serif.",
        "fallback_rationale": "The approved board names Inter for UI, IBM Plex Mono for code, and Source Serif 4/Georgia as an optional long-form documentation voice. These are practical open-source or system-safe choices.",
        "avoid_fonts": "Avoid Impact, novelty stencil fonts, overly condensed industrial display faces, and distressed type."
      }
