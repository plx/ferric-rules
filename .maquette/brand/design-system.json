  "meta": {
    "system_name": "ferric-rules Industrial Drafting System",
    "platform": "web",
    "version": "1.0.0",
    "status": "approved",
    "source_mode": "greenfield",
    "created_at": "2026-05-12T05:57:41-07:00",
    "last_updated_at": "2026-05-12T05:57:41-07:00",
    "notes": "Derived from approved brand board v1. The board establishes an industrial drafting visual system for documentation-forward web UI; it does not define the logo."
  },
  "brief": {
    "product_summary": "A mostly CLIPS-compatible forward-chaining rules engine in Rust, built for easy embedding as independent engine instances in modern applications.",
    "audience": "Rust developers, teams migrating practical CLIPS rule sets, SDK and binding authors, and engineers reading long-form implementation documentation.",
    "tone": [
      "industrial",
      "precise",
      "durable",
      "restrained",
      "technical",
      "architectural",
      "non-fatiguing"
    ],
    "keywords": [
      "steel",
      "ferric oxide",
      "architectural drafting",
      "Rete network",
      "embedded runtime",
      "CLIPS compatibility",
      "Rust"
    ],
    "constraints": [
      "Keep rust tones as accents rather than dominant page color.",
      "Use fine drafting lines only as low-contrast support texture behind content.",
      "Avoid gritty decay, mascots, humanoid figures, and generic SaaS gloss.",
      "Keep documentation pages quiet enough for repeated reading.",
      "Do not treat the brand-board image as a logo source."
    ],
    "accessibility": {
      "contrast_target": "AA",
      "reduced_motion_support": true,
      "focus_visibility": "high-contrast",
      "min_hit_target_px": 44,
      "notes": "Rust/ferric accents must not be used for long body copy. Focus indicators should combine color, outline, and shape."
    }
  },
  "references": [
    {
      "kind": "brand-board",
      "path": ".maquette/brand/brand-board-v1.png",
      "role": "primary",
      "notes": "Approved 1:1 visual-system board with steel graphite neutrals, ferric oxide accents, drafting lines, structural girders, and abstract Rete network geometry."
    }
  ],
