;;; ********************************
;;; locked-candidate-single-line-row
;;; ********************************

(defrule locked-candidate-single-line-row

   (phase match)

   (rank (value ?p) (process yes))

   (technique (name Locked-Candidate-Single-Line) (rank ?p))
   
