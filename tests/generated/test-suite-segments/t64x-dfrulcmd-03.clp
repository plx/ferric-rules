(defrule bar1 => (assert (a)))
(defrule bar2 (a) => (assert (b)))
(defrule bar3 (b) 
   => 
   (assert (c)) 
   (rules)
   (printout t "-------" crlf)
   (undefrule *)
   (rules)
   (printout t "-------" crlf)
   (load "Temp//foo.tmp")
   (rules)
   (printout t "-------" crlf))
(defrule bar4 (a) (b) (c) =>)
